# Local .terraform folders
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude sensitive vars
*.tfvars
!environments/dev/terraform.tfvars # Only if you want to keep example vars (optional)

# Variables and secret files
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include logs
*.log

# Ignore plan files
tfplan
tfplan.binary
